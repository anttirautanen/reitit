{
  "name": "reitit",
  "workspaces": [
    "back",
    "front"
  ],
  "scripts": {
    "start": "concurrently \"npm run start:front\" \"npm run start:back\"",
    "start:front": "npm --workspace=front run dev",
    "start:back": "npm --workspace=back run dev"
  },
  "devDependencies": {
    "concurrently": "9.2.1"
  }
}
